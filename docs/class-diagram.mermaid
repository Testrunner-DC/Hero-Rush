classDiagram
    %% ═══════════════════════════════════════════════════
    %% TypeScript 类型定义
    %% ═══════════════════════════════════════════════════

    class AuthUser {
        +string id
        +string email
        +string nickname
        +string? avatar_url
        +string bio
        +string created_at
    }

    class AuthState {
        +AuthUser? user
        +Session? session
        +boolean isLoading
        +boolean isAuthenticated
    }

    class ProfileFormData {
        +string nickname
        +string bio
        +File? avatarFile
    }

    class Deck {
        +string? id
        +string? user_id
        +string name
        +DeckEntry[] main_deck
        +DeckEntry[] rush_deck
        +string created_at
        +string? description
        +boolean? is_published
        +string? author_nickname
        +string? author_avatar_url
        +number? favorite_count
        +boolean? is_favorited
    }

    class DeckEntry {
        +string card_no
        +number count
    }

    class UserRow {
        +string id
        +string email
        +string nickname
        +string? avatar_url
        +string bio
        +string created_at
    }

    class DeckRow {
        +string id
        +string user_id
        +string title
        +string description
        +string cards_json
        +boolean is_published
        +string created_at
        +string updated_at
    }

    class FavoriteRow {
        +string id
        +string user_id
        +string deck_id
        +string created_at
    }

    class BattleRecordRow {
        +string id
        +string winner_id
        +string loser_id
        +number rounds
        +string battle_at
    }

    class SeasonRankingRow {
        +string id
        +string user_id
        +string season_id
        +number score
        +number wins
        +number losses
        +number draws
    }

    class CommentRow {
        +string id
        +string user_id
        +string deck_id
        +string content
        +string created_at
    }

    %% ═══════════════════════════════════════════════════
    %% React Context
    %% ═══════════════════════════════════════════════════

    class AuthContext {
        +AuthState state
        +signUp(email, password, nickname) Promise~void~
        +signIn(email, password) Promise~void~
        +signOut() Promise~void~
        +refreshProfile() Promise~void~
    }

    %% ═══════════════════════════════════════════════════
    %% Service 层
    %% ═══════════════════════════════════════════════════

    class AuthService {
        +signUp(email, password, nickname) Promise~AuthResult~
        +signIn(email, password) Promise~AuthResult~
        +signOut() Promise~void~
        +getSession() Promise~Session?~
    }

    class UserService {
        +getProfile(userId) Promise~UserRow?~
        +updateProfile(userId, data) Promise~UserRow?~
        +uploadAvatar(userId, file) Promise~string~
    }

    class DeckService {
        +fetchPublishedDecks() Promise~DeckRow[]~
        +fetchMyDecks(userId) Promise~DeckRow[]~
        +createDeck(userId, data) Promise~DeckRow?~
        +updateDeck(deckId, data) Promise~DeckRow?~
        +deleteDeck(deckId) Promise~void~
        +publishDeck(userId, data) Promise~DeckRow?~
    }

    class FavoriteService {
        +fetchFavorites(userId) Promise~FavoriteRow[]~
        +addFavorite(userId, deckId) Promise~FavoriteRow?~
        +removeFavorite(userId, deckId) Promise~void~
        +isFavorited(userId, deckId) Promise~boolean~
        +getFavoriteCount(deckId) Promise~number~
    }

    class MigrationService {
        +detectLocalDecks() Deck[]
        +migrateDecksToCloud(userId) Promise~number~
        +clearLocalDecks() void
    }

    %% ═══════════════════════════════════════════════════
    %% Hooks
    %% ═══════════════════════════════════════════════════

    class useAuth {
        +AuthUser? user
        +boolean isAuthenticated
        +boolean isLoading
        +signUp(email, password, nickname) Promise~void~
        +signIn(email, password) Promise~void~
        +signOut() Promise~void~
    }

    class useProfile {
        +UserRow? profile
        +boolean isLoading
        +updateProfile(data) Promise~void~
        +uploadAvatar(file) Promise~void~
    }

    class useDecks {
        +Deck[] publishedDecks
        +Deck[] myDecks
        +boolean isLoading
        +publishDeck(data) Promise~void~
        +deleteDeck(deckId) Promise~void~
        +refresh() Promise~void~
    }

    class useFavorites {
        +Set~string~ favoriteDeckIds
        +toggleFavorite(deckId) Promise~void~
        +isFavorited(deckId) boolean
        +getFavoriteCount(deckId) number
    }

    %% ═══════════════════════════════════════════════════
    %% 组件
    %% ═══════════════════════════════════════════════════

    class App {
        +BrowserRouter
        +Routes
        +NavigationBar
    }

    class AuthPage {
        +mode: "login" | "register"
        +onSubmit()
        +switchMode()
    }

    class AuthModal {
        +open: boolean
        +onClose()
        +onSuccess()
    }

    class UserMenu {
        +user: AuthUser
        +onSignOut()
        +navigateToProfile()
    }

    class ProfilePage {
        +userId: string
        +profile: UserRow
        +isOwner: boolean
    }

    class ProfileEditor {
        +profile: UserRow
        +onSave(data)
        +onCancel()
    }

    class AvatarUpload {
        +currentUrl: string?
        +onUploaded(url)
        +isUploading: boolean
    }

    class PublishDeckModal {
        +open: boolean
        +deck: Deck
        +onPublish(data)
        +onClose()
    }

    class DeckPlazaPage {
        +publishedDecks: Deck[]
        +myDecks: Deck[]
        +onToggleFavorite(deckId)
        +onImportCode(code)
    }

    class DeckBuilderPage {
        +deckState
        +onPublishClick()
        +onAddCard(card)
        +onRemoveCard(cardNo)
    }

    %% ═══════════════════════════════════════════════════
    %% 关系
    %% ═══════════════════════════════════════════════════

    AuthContext --> AuthState : manages
    AuthContext --> AuthUser : contains
    AuthContext --> AuthService : calls
    AuthContext --> UserService : calls
    AuthContext --> MigrationService : calls

    useAuth --> AuthContext : consumes
    useProfile --> UserService : calls
    useDecks --> DeckService : calls
    useFavorites --> FavoriteService : calls

    App --> AuthContext : provides
    App --> AuthPage : routes
    App --> ProfilePage : routes
    App --> DeckPlazaPage : routes
    App --> DeckBuilderPage : routes
    App --> UserMenu : renders in nav

    AuthPage --> useAuth : uses
    AuthModal --> useAuth : uses
    UserMenu --> useAuth : uses

    ProfilePage --> useProfile : uses
    ProfilePage --> ProfileEditor : renders
    ProfilePage --> AvatarUpload : renders

    DeckPlazaPage --> useDecks : uses
    DeckPlazaPage --> useFavorites : uses
    DeckPlazaPage --> useAuth : uses
    DeckPlazaPage --> AuthModal : renders

    DeckBuilderPage --> useAuth : uses
    DeckBuilderPage --> PublishDeckModal : renders

    UserRow --|> AuthUser : maps to
    DeckRow ..|> Deck : maps to

    Deck "1" *-- "50" DeckEntry : contains
